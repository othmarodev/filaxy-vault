{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Filaxy Vault",
  "version": "0.1.0",
  "identifier": "app.filaxy.vault",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      { "title": "Filaxy™ Vault", "width": 1000, "height": 700, "minWidth": 760, "minHeight": 520 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
